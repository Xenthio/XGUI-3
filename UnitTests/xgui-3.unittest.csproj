<Project Sdk="Microsoft.NET.Sdk.Razor">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<AssemblyName>xgui-3.unittest</AssemblyName>
		<PackageId>xgui-3.unittest</PackageId>
		<LangVersion>14</LangVersion>
		<NoWarn>1701;1702;1591;</NoWarn>
		<WarningsAsErrors></WarningsAsErrors>
		<TreatWarningsAsErrors>False</TreatWarningsAsErrors>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<DefineConstants>SANDBOX;ADDON;DEBUG</DefineConstants>
		<AllowUnsafeBlocks>False</AllowUnsafeBlocks>
		<OutputPath>../../../../../SteamLibrary/steamapps/common/sbox/.vs/output/</OutputPath>
		<DocumentationFile>../../../../../SteamLibrary/steamapps/common/sbox/.vs/output/xgui-3.unittest.xml</DocumentationFile>
		<RootNamespace>XGUI</RootNamespace>
		<Nullable>disable</Nullable>
		<IsTestProject>true</IsTestProject>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" /> 
		<PackageReference Include="MSTest.TestAdapter" Version="3.6.4" /> 
		<PackageReference Include="MSTest.TestFramework" Version="3.6.4" /> 
		<PackageReference Include="coverlet.collector" Version="6.0.2" /> 
	</ItemGroup>

	<ItemGroup>
		<Using Include="Sandbox.Internal.GlobalToolsNamespace" Static="true" />
		<Using Include="Sandbox.Internal.GlobalGameNamespace" Static="true" />
	</ItemGroup>

	<ItemGroup>
		<Analyzer Include="../../../../../SteamLibrary/steamapps/common/sbox/bin/managed/Sandbox.CodeUpgrader.dll"/> 
